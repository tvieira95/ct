  Button
    id: specialFoodsButton
    height: 24
    anchors.top: prev.bottom
    anchors.left: parent.left
    anchors.right: parent.right
    margin-top: 7
    text: Special Foods
    font: $var-main-font
    @onClick: modules.game_helper.specialFoodsOpen()

  Panel
    id: healingTargetModePanel
    height: 24
    anchors.top: prev.bottom
    anchors.left: parent.left
    anchors.right: parent.right
    margin-top: 7
    image-source: /images/ui/button-grey-up
    image-border: 5
    enabled: true
    visible: false
    Label
      id: targetModeLabel
      anchors.left: parent.left
      anchors.verticalCenter: parent.verticalCenter
      margin-left: 10
      !text: tr('Heal Target:')
      font: $var-main-font
      color: #AAAAAA
      text-auto-resize: true
    CheckBox
      id: targetModeScreen
      anchors.left: targetModeLabel.right
      anchors.verticalCenter: parent.verticalCenter
      margin-left: 10
      width: 70
      !text: tr('Screen')
      font: $var-main-font
      color: $var-text-color
      text-offset: 13 0
      change-cursor-image: false
    CheckBox
      id: targetModeParty
      anchors.left: targetModeScreen.right
      anchors.verticalCenter: parent.verticalCenter
      margin-left: 10
      width: 60
      !text: tr('Party')
      font: $var-main-font
      color: $var-text-color
      text-offset: 13 0
      change-cursor-image: false

  Panel
    id: friendHealingPanel
    height: 145
    anchors.top: prev.bottom
    anchors.left: parent.left
    anchors.right: parent.right
    margin-top: 7
    image-source: /images/ui/t2pixel-up-frame-borderimage
    image-border: 18
    enabled: true
    visible: false
    Label
      id: friendTitle
      anchors.top: parent.top
      anchors.horizontalCenter: parent.horizontalCenter
      margin-top: 1
      !text: tr('Heal Friend Helper')
      font: $var-main-font
      color: #AAAAAA
      text-auto-resize: true
    Panel
      id: vocFriendPanel
      anchors.top: friendTitle.bottom
      anchors.left: parent.left
      anchors.right: parent.right
      anchors.bottom: parent.bottom
      margin: 3 8 5 8

      Label
        id: headerVoc
        anchors.top: parent.top
        anchors.left: parent.left
        margin-top: 2
        !text: tr('Vocation')
        font: $var-main-font
        color: #888888
        text-auto-resize: true
      Label
        id: headerHp
        anchors.top: parent.top
        anchors.left: parent.left
        margin-top: 2
        margin-left: 120
        !text: tr('HP%%')
        font: $var-main-font
        color: #888888
        text-auto-resize: true
      Label
        id: headerPrio
        anchors.top: parent.top
        anchors.left: parent.left
        margin-top: 2
        margin-left: 200
        !text: tr('Priority')
        font: $var-main-font
        color: #888888
        text-auto-resize: true

      CheckBox
        id: enableFriendKnight
        width: 110
        anchors.top: headerVoc.bottom
        anchors.left: parent.left
        margin-top: 8
        !text: tr('Knight')
        font: $var-main-font
        color: $var-text-color
        text-offset: 13 0
        change-cursor-image: false
        @onCheckChange: modules.game_helper.onEnableVocFriend('knight', self:isChecked())
      ComboBox
        id: friendPercentKnight
        size: 55 18
        anchors.top: enableFriendKnight.top
        anchors.left: parent.left
        margin-left: 120
        color: $var-text-color
        font: $var-main-font
        @onOptionChange: modules.game_helper.updateVocFriendPercent('knight', self:getCurrentOption().text:match("%d+"))
        @onSetup: |
          for i = 10, 100, 10 do
            if i == 100 then i = 99 end
            self:addOption(i .. "%")
          end
          self:setCurrentOption("90%")
      ComboBox
        id: friendPriorityKnight
        size: 45 18
        anchors.top: enableFriendKnight.top
        anchors.left: parent.left
        margin-left: 200
        color: $var-text-color
        font: $var-main-font
        @onOptionChange: modules.game_helper.updateVocFriendPriority('knight', self:getCurrentOption().text)
        @onSetup: |
          for i = 1, 5 do self:addOption(tostring(i)) end
          self:setCurrentOption("5")

      CheckBox
        id: enableFriendPaladin
        width: 110
        anchors.top: enableFriendKnight.bottom
        anchors.left: parent.left
        margin-top: 9
        !text: tr('Paladin')
        font: $var-main-font
        color: $var-text-color
