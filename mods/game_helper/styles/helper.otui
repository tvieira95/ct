HelperRules < NewHeadlessWindow
  id: helperRules
  anchors.horizontalCenter: parent.horizontalCenter
  size: 450 345
  @onEscape: hide()
  UIWidget
    size: 145 56
    anchors.top: parent.top
    anchors.horizontalCenter: parent.horizontalCenter
    margin-top: -33
    image-source: /images/game/tutorial/backdrop_crest
    phantom: true

  Panel
    id: contentPanel
    anchors.fill: parent
    margin: 15 13 17 13
    TextList
      id: rules
      anchors.top: parent.top
      anchors.left: parent.left
      anchors.right: parent.right
      anchors.bottom: separator.top
      margin-top: 10
      margin-bottom: 10
      text-align: center
      padding: 1
      focusable: false
      background-color: $var-textlist-odd
    
    HorizontalSeparator
      id: separator
      anchors.bottom: next.top
      anchors.left: parent.left
      anchors.right: parent.right
      margin-bottom: 10
    Button
      id: next
      anchors.bottom: parent.bottom
      anchors.right: parent.right
      !text: tr('Next')
      size: 43 20
      enabled: false
      @onClick: modules.game_helper:onHelperTermConditionNext()
    CloseButton
      id: close
      anchors.bottom: parent.bottom
      anchors.right: prev.left
      margin-right: 5
      @onClick: modules.game_helper.closeTerms()
    CheckBox
      id: termCondition
      width: 100
      anchors.bottom: parent.bottom
      anchors.left: parent.left
      text-offset: 16 -2
      !text: tr('I agree with OTC Terms and Conditions.')
      !tooltip: tr('I have read and I agree to the Extended OTC Service Agreement and the OTC Privacy Policy.')
      margin-bottom: 5
      font: $var-main-font
      color: $var-text-color
      text-auto-resize: true
      @onCheckChange: modules.game_helper.onHelperTermCondition(self:getId(), self:isChecked())


PlayerName < Label
  focusable: true
  height: 15
  font: $var-main-font
  color: #AAAAAA

  $focus:
    background-color: $var-textlist-odd
    color: $var-text-cip-color-highlight
  $!focus:
    background-color: alpha
    color: $var-text-cip-color

PotionItem < UIItem
  size: 32 32
  phantom: true
  draggable: false
  virtual: true
  priceable: false
  anchors.top: parent.top
  anchors.left: parent.left

RuneItem < UIItem
  size: 32 32
  phantom: true
  draggable: false
  virtual: true
  priceable: false
  anchors.top: parent.top
  anchors.left: parent.left

FoodItem < UIItem
  size: 32 32
  phantom: true
  draggable: false
  virtual: true
  priceable: false
  anchors.top: parent.top
  anchors.left: parent.left

SpecialFoodsWindow < MainWindow
  id: specialFoodsWindow
  size: 440 260
  !text: tr('Special Foods')
  @onEscape: modules.game_helper.specialFoodsClose()

  Panel
    id: hpFoodsPanel
    anchors.top: parent.top
    anchors.left: parent.left
    anchors.bottom: specialFoodsSeparator.top
    width: 200
    margin-top: 1
    margin-bottom: 5
    image-source: /images/ui/t2pixel-up-frame-borderimage
    image-border: 18

    Label
      id: hpTitle
      anchors.top: parent.top
      anchors.left: parent.left
      margin-top: 3
      margin-left: 5
      !text: tr('HP Foods')
      font: $var-main-font
      color: #d94a3a
      text-auto-resize: true

    Label
      id: hpPriorityHeader
      anchors.top: parent.top
      anchors.right: parent.right
      margin-top: 3
      margin-right: 5
      !text: tr('Priority')
      font: $var-main-font
      color: $var-text-color
      text-auto-resize: true

    UIButton
      id: hpFoodSlot0
      size: 34 34
      anchors.top: hpTitle.bottom
      anchors.left: parent.left
      margin-left: 2
      margin-top: 3
      image-source: /images/game/actionbar/actionbarslot
    CheckBox
      id: hpFoodEnable0
      width: 12
      anchors.verticalCenter: hpFoodSlot0.verticalCenter
      anchors.left: hpFoodSlot0.right
      margin-left: 3
      change-cursor-image: false
      @onCheckChange: modules.game_helper.toggleSpecialFood('hp', 1, self:isChecked())
    UIButton
      id: hpFoodRmvPercent0
      size: 10 24
      anchors.verticalCenter: hpFoodSlot0.verticalCenter
      anchors.left: hpFoodEnable0.right
      margin-left: 3
      image-source: /images/ui/percent-buttons
      image-clip: 0 0 10 24
      @onSetup: |
        g_mouse.bindAutoPress(self, function() modules.game_helper.updateSpecialFoodPercent('hp', 1, -1) end, 150)
      $hover !pressed:
        image-clip: 0 24 10 24
      $pressed:
        image-clip: 0 48 10 24
    FlatPanel
      id: hpFoodPercentBg0
      size: 38 24
      image-source: /images/ui/percentBg
      anchors.verticalCenter: hpFoodSlot0.verticalCenter
      anchors.left: hpFoodRmvPercent0.right
      margin-left: 1
      Label
        id: hpFoodPercentLabel0
        anchors.top: parent.top
        anchors.horizontalCenter: parent.horizontalCenter
        margin-top: 4
        !text: tr('80%%')
        font: $var-main-font
        color: $var-text-color
        text-auto-resize: true
    UIButton
      id: hpFoodAddPercent0
      size: 10 24
      anchors.verticalCenter: hpFoodSlot0.verticalCenter
      anchors.left: hpFoodPercentBg0.right
      margin-left: 1
      image-source: /images/ui/percent-buttons
      image-clip: 10 0 10 24
      @onSetup: |
        g_mouse.bindAutoPress(self, function() modules.game_helper.updateSpecialFoodPercent('hp', 1, 1) end, 150)
      $hover !pressed:
        image-clip: 10 24 10 24
      $pressed:
        image-clip: 10 48 10 24
    UIButton
      id: hpFoodAddPriority0
      size: 10 24
      anchors.verticalCenter: hpFoodSlot0.verticalCenter
      anchors.right: parent.right
      margin-right: 2
      image-source: /images/ui/percent-buttons
      image-clip: 10 0 10 24
      @onSetup: |
